{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "artisan",
                "boost:mcp"
            ]
        }
    },
    "permission": {
        "edit": "ask",
        "bash": "ask",
        "skill": "allow"
    },
    "watcher": {
        "ignore": [
            "node_modules/**",
            "dist/**",
            ".git/**"
        ]
    },
    "instructions": [
        "AGENTS.md",
        ".docs/*.md"
    ]
}
